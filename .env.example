# AlphaCouncil AI - Vercel 环境变量配置参考
# 本文件仅供参考，实际部署时请在 Vercel 项目设置中配置环境变量
# 路径：项目设置 → Environment Variables

# Google Gemini API 配置（必需）
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API 配置（必需）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Twelve Data 黄金行情配置（推荐）
# 获取地址: https://twelvedata.com/
# 用途: XAU/USD quote + 15min/1h/4h/1day K线
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
# 用途: 人民币参考换算，默认用离岸人民币 USD/CNH；如你的套餐支持 USD/CNY 也可改
TWELVE_DATA_FX_SYMBOL=USD/CNH
# 用途: Twelve Data K线时间展示校准。当前 XAU/USD 返回时间对国内显示偏快约2小时，所以默认 -120
TWELVE_DATA_TIME_OFFSET_MINUTES=-120
USD_CNY=7.20

# 自定义黄金行情源（可选兜底）
GOLD_PRICE_API_URL=
GOLD_PRICE_API_KEY=

# 长期行情/分析快照存储（必需：如果要跨浏览器、跨设备长期留存）
# Vercel KV 或 Upstash Redis 会提供这两个值
KV_REST_API_URL=your_kv_rest_api_url_here
KV_REST_API_TOKEN=your_kv_rest_api_token_here
MARKET_HISTORY_KEY=alphacouncil:market-history:xauusd
MARKET_HISTORY_LIMIT=1000
